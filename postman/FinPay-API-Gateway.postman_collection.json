            "{{gatewayBaseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "me"
          ]
        }
      }
    },
    {
      "name": "Create Sender Wallet Through Gateway",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
