            "{{gatewayBaseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "wallets",
            "{{senderWalletId}}",
            "transactions"
          ]
        }
      }
    },
    {
      "name": "Check Sender Balance Through Gateway",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Sender balance through gateway returns 200 OK', function () {",
              "  pm.response.to.have.status(200);",
