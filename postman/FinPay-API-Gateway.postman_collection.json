    {
      "name": "Transfer Money Through Gateway",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.collectionVariables.set('idempotencyKey', 'gateway-transfer-' + Date.now());"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Transfer through gateway returns 200 OK', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Transfer stores payment reference', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.success).to.eql(true);",
              "  pm.expect(json.data.status).to.eql('SUCCESS');",
              "  pm.expect(json.data.paymentReference).to.be.a('string').and.not.empty;",
              "  pm.collectionVariables.set('paymentReference', json.data.paymentReference);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"senderWalletId\": {{senderWalletId}},\n  \"receiverWalletId\": {{receiverWalletId}},\n  \"amount\": 500.00,\n  \"currency\": \"INR\",\n  \"idempotencyKey\": \"{{idempotencyKey}}\"\n}"
        },
        "url": {
          "raw": "{{gatewayBaseUrl}}/api/v1/payments/transfer",
          "host": [
            "{{gatewayBaseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "payments",
            "transfer"
          ]
        }
      }
    },
