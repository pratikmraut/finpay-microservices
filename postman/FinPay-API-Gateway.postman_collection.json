  "item": [
    {
      "name": "Gateway Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{gatewayBaseUrl}}/actuator/health",
          "host": [
            "{{gatewayBaseUrl}}"
          ],
          "path": [
            "actuator",
            "health"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Gateway health returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Register User Through Gateway",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const unique = Date.now();",
              "pm.collectionVariables.set('userEmail', 'gateway' + unique + '@example.com');",
              "pm.collectionVariables.set('userPhone', '98' + String(unique).slice(-8));"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Register through gateway returns 201 Created', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Register response contains user email', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.success).to.eql(true);",
              "  pm.expect(json.data.email).to.eql(pm.collectionVariables.get('userEmail'));",
              "  pm.collectionVariables.set('userId', json.data.userId);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"Gateway User\",\n  \"email\": \"{{userEmail}}\",\n  \"phone\": \"{{userPhone}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{gatewayBaseUrl}}/api/v1/auth/register",
          "host": [
            "{{gatewayBaseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "register"
          ]
        }
      }
    },
    {
      "name": "Login User Through Gateway",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Login through gateway returns 200 OK', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Login stores JWT token and user id', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.success).to.eql(true);",
              "  pm.expect(json.data.accessToken).to.be.a('string').and.not.empty;",
              "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
              "  pm.collectionVariables.set('userId', json.data.userId);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{gatewayBaseUrl}}/api/v1/auth/login",
          "host": [
            "{{gatewayBaseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "login"
          ]
        }
      }
    },
    {
      "name": "Get Current User Through Gateway",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Current user through gateway returns 200 OK', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Current user email matches registered user', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.data.email).to.eql(pm.collectionVariables.get('userEmail'));",
              "});"
            ]
          }
        }
      ],
