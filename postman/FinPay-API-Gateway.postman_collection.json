    {
      "name": "Get Sender Transactions Through Gateway",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Get transactions through gateway returns 200 OK', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Transactions include payment reference', function () {",
              "  const json = pm.response.json();",
              "  const refs = json.data.map(item => item.paymentReference);",
              "  pm.expect(refs).to.include(pm.collectionVariables.get('paymentReference'));",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
