    {
      "name": "Simulate Notification Event Through Gateway",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.collectionVariables.set('eventId', 'gateway-event-' + Date.now());"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Notification event through gateway returns 200 OK', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Notification is created', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.success).to.eql(true);",
              "  pm.expect(json.data.paymentReference).to.eql(pm.collectionVariables.get('paymentReference'));",
              "  pm.expect(json.data.status).to.eql('CREATED');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-INTERNAL-SERVICE-TOKEN",
            "value": "{{internalServiceToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"eventId\": \"{{eventId}}\",\n  \"paymentReference\": \"{{paymentReference}}\",\n  \"senderWalletId\": {{senderWalletId}},\n  \"receiverWalletId\": {{receiverWalletId}},\n  \"amount\": 500.00,\n  \"currency\": \"INR\",\n  \"status\": \"SUCCESS\",\n  \"eventType\": \"PAYMENT_COMPLETED\",\n  \"message\": \"Payment completed successfully\",\n  \"createdAt\": \"2026-06-22T00:00:00Z\"\n}"
        },
        "url": {
          "raw": "{{gatewayBaseUrl}}/internal/v1/notifications/payment-events",
          "host": [
            "{{gatewayBaseUrl}}"
          ],
          "path": [
            "internal",
            "v1",
            "notifications",
            "payment-events"
          ]
        }
      }
    },
    {
      "name": "Get Notification By Payment Through Gateway",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Get notification through gateway returns 200 OK', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Notification list contains payment reference', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.data.length).to.be.above(0);",
              "  pm.expect(json.data[0].paymentReference).to.eql(pm.collectionVariables.get('paymentReference'));",
              "});"
            ]
          }
        }
